POSTGRES_USER=metabase
POSTGRES_DB=metabase
POSTGRES_PASSWORD=change_me_strong_password

# Public URL of the Metabase instance (used in MB_SITE_URL)
MB_SITE_URL=https://data.neolaiacampus.eu/metabase/admin/

# Full URL where Metabase is reachable FROM THE BROWSER (used to build embed URLs)
METABASE_SITE_URL=https://data.neolaiacampus.eu/metabase

METABASE_SECRET_KEY=your_metabase_secret_key_here

FRONTEND_PORT=8080

# CORS_ORIGINS=https://mysite.com,https://other.example.com
CORS_ORIGINS=
